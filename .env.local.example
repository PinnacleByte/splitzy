NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — Project Settings > API > service_role secret. Never expose
# to the client, never commit. Full bypass-RLS access to your database.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# The one account allowed to create friend accounts (see lib/adminActions.ts).
NEXT_PUBLIC_ADMIN_EMAIL=you@email.com
