NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — Project Settings > API > service_role secret. Never expose
# to the client, never commit. Full bypass-RLS access to your database.
# Used by lib/accountActions.ts to create accounts via the admin API (no
# confirmation email, so no rate-limited email sender is ever involved).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
